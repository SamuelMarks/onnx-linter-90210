{
  "name": "onnx-linter-90210",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "lint": "eslint . --ext .ts",
    "test": "c8 --check-coverage --lines 100 --functions 100 --branches 100 tsx --test 'src/**/*.test.ts' 'src/*.test.ts'",
    "build": "tsc",
    "prepare": "simple-git-hooks",
    "build:web": "esbuild src/index.ts --bundle --outfile=dist/browser.js --format=iife --global-name=OnnxLinter"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run lint && npm run test"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser": "^7.8.0",
    "c8": "^9.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^8.57.0",
    "eslint-plugin-jsdoc": "^48.2.3",
    "simple-git-hooks": "^2.11.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
